# --- Airtable (existing dashboard + /calculator) ---
# Personal Access Token from https://airtable.com/create/tokens
# Scopes required: data.records:read, data.records:write
# Access: only the "Wedding Budget" base.
AIRTABLE_PAT=patXXXXXXXXXXXXXX.XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# --- Supabase (login + per-user wedding budgets at /weddings) ---
# From the Supabase dashboard: Project Settings → API.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- AI Chatbot (Anthropic API, direct) ---
# Create a key at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Google Maps (Places autocomplete in /properties) ---
# Get a browser API key at https://console.cloud.google.com/apis/credentials
# Required APIs: "Maps JavaScript API" + "Places API". Restrict the key by
# HTTP referrer (your local + production domains) so it can't be abused.
# Without this, the property form still works — the Google search just disappears.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=AIzaXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
